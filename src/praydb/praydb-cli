
from __future__ import annotations

import argparse
import json
import os
import sys
from pathlib import Path
from typing import Any, Optional

from .core import PrayDB, PrayDBError


def _json_default(value: Any) -> str:
    return str(value)


def _print_json(value: Any) -> None:
    print(json.dumps(value, indent=2, sort_keys=True, ensure_ascii=False, default=_json_default))


def _parse_value(raw: str) -> Any:
    try:
        return json.loads(raw)
    except json.JSONDecodeError:
        return raw


def _default_context_file(user_id: str) -> str:
    return str(Path.home() / ".praydb" / f"{user_id}.json")


def _make_db(args: argparse.Namespace) -> PrayDB:
    api_key = args.api_key or os.environ.get("OPENROUTER_API_KEY")
    context_file = None if args.no_context_file else (args.context_file or _default_context_file(args.user_id))
    return PrayDB(
        api_key=api_key,
        model=args.model,
        user_id=args.user_id,
        context_file=context_file,
        base_url=args.base_url,
        timeout=args.timeout,
        retries=args.retries,
        temperature=args.temperature,
        max_tokens=args.max_tokens,
    )


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="praydb",
        description="PrayDB: the database that stores your data in an LLM context window and prays.",
        epilog="Examples: praydb set lupc timezone GMT+3; praydb dump; praydb doctor",
    )
    parser.add_argument("--api-key", help="OpenRouter API key. Defaults to OPENROUTER_API_KEY.")
    parser.add_argument("--model", default="openai/gpt-4o-mini", help="OpenRouter model name.")
    parser.add_argument("--user-id", default="default", help="User namespace/id.")
    parser.add_argument("--context-file", help="Local prompt-scroll JSON file. Default: ~/.praydb/<user-id>.json")
    parser.add_argument("--no-context-file", action="store_true", help="Do not read/write a local context file.")
    parser.add_argument("--base-url", default="https://openrouter.ai/api/v1", help="OpenRouter-compatible base URL.")
    parser.add_argument("--timeout", type=int, default=30, help="HTTP timeout in seconds.")
    parser.add_argument("--retries", type=int, default=3, help="Retry attempts for model calls.")
    parser.add_argument("--temperature", type=float, default=0, help="Model temperature. Keep it 0 unless you want jazz.")
    parser.add_argument("--max-tokens", type=int, default=2048, help="Max response tokens.")
    parser.add_argument("--pretty", action="store_true", help="Pretty-print JSON. Enabled by default for humans.")

    subparsers = parser.add_subparsers(dest="command", required=True)

    set_parser = subparsers.add_parser("set", help="Set a key to a JSON value or plain string.")
    set_parser.add_argument("key")
    set_parser.add_argument("value")

    get_parser = subparsers.add_parser("get", help="Get one key or the whole state.")
    get_parser.add_argument("key", nargs="?")

    subparsers.add_parser("dump", help="Dump the full database state.")
    subparsers.add_parser("keys", help="List keys in the local context state.")

    delete_parser = subparsers.add_parser("delete", help="Delete one key.")
    delete_parser.add_argument("key")

    reset_parser = subparsers.add_parser("reset", help="Reset the database state.")
    reset_parser.add_argument("--yes", action="store_true", help="Confirm reset.")

    subparsers.add_parser("doctor", help="Run a tiny end-to-end model discipline test.")
    subparsers.add_parser("export", help="Export the current prompt/context scroll as JSON.")
    subparsers.add_parser("prompt", help="Print the last generated model prompt after a read/dump.")

    return parser


def main(argv: Optional[list[str]] = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)

    try:
        db = _make_db(args)

        if args.command == "set":
            result = db.set(args.key, _parse_value(args.value))
            _print_json(result)
            return 0

        if args.command == "get":
            result = db.get(args.key)
            _print_json(result)
            return 0

        if args.command == "dump":
            result = db.dump()
            _print_json(result)
            return 0

        if args.command == "keys":
            _print_json(db.keys())
            return 0

        if args.command == "delete":
            result = db.delete(args.key)
            _print_json(result)
            return 0

        if args.command == "reset":
            result = db.reset(confirm=args.yes)
            _print_json(result)
            return 0

        if args.command == "doctor":
            result = db.doctor()
            _print_json(result)
            return 0 if result.get("ok") else 2

        if args.command == "export":
            print(db.export_context())
            return 0

        if args.command == "prompt":
            db.dump()
            print(db.last_prompt or "")
            return 0

    except PrayDBError as exc:
        print(f"PrayDB error: {exc}", file=sys.stderr)
        return 1

    parser.print_help()
    return 0


if __name__ == "__main__":  # pragma: no cover
    raise SystemExit(main())